{
  "name": "myntra-earning-platform",
  "version": "1.0.0",
  "description": "Myntra task/commission earning platform clone",
  "main": "backend/server.js",
  "scripts": {
    "init-project": "npm install",
    "backend": "node backend/server.js",
    "frontend:dev": "vite frontend",
    "frontend:build": "vite build frontend --outDir ../backend/public --emptyOutDir",
    "dev": "concurrently \"npm run backend\" \"npm run frontend:dev\"",
    "build": "npm run frontend:build",
    "start": "node backend/server.js"
  },
