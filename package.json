    "axios": "^1.18.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^8.6.0",
    "framer-motion": "^12.42.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.378.0",
    "mongoose": "^9.7.4",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "mysql2": "^3.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.81.0",
    "react-hot-toast": "^2.6.0",
